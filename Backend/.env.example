# Example environment for local development.
# Copy to .env and adjust values.

APP_NAME=SME Credit Risk API
APP_ENV=development
DEBUG=true

# SQLite for local; on Render this is replaced by Postgres DATABASE_URL
DATABASE_URL=sqlite:///./data/sme_credit.db

# In production these MUST be strong unique secrets (Render generateValue).
SECRET_KEY=dev-secret-key-change-in-production
PSEUDONYMIZATION_KEY=dev-pseudonymization-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_ENABLED=true

# Comma-separated browser origins (exact list in production; no wildcards).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MODEL_DIR=./models
MIN_TRANSACTIONS_FOR_SCORE=5
RANDOM_SEED=42
MAX_FINANCING_TZS=50000000
MIN_FINANCING_TZS=500000
